{
  "mcpServers": {
    "azure-devops": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "xrbarbosa",
        "--authentication",
        "envvar",
        "-d",
        "core",
        "work-items"
      ],
      "env": {
        "ADO_MCP_AUTH_TOKEN": "${AZURE_DEVOPS_PAT}",
        "AZURE_DEVOPS_DEFAULT_PROJECT": "EffortIQ"
      }
    }
  }
}